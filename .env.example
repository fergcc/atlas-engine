# ============================================================
# Atlas Engine — Environment Configuration
# ============================================================
# TODOS los valores reales viven en ~/.secrets/scientika.env
# Este archivo solo contiene placeholders y se commitea.
# ============================================================

# ---- Engine ----
ENGINE_ENV=development
ENGINE_USE_MOCKS=true
ENGINE_DB_PATH=data/engine.db
ENGINE_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ---- SearchAPI.io — Web & scholar search (paid, company-wide) ----
SEARCH_API_KEY=__PLACEHOLDER__

# ---- DeepSeek — LLM para clasificación sectorial, extracción de indicadores, narrativas ----
DEEPSEEK_API_KEY=__PLACEHOLDER__

# ---- UN Comtrade — Balanza comercial, ventaja comparativa revelada (free, registration required) ----
COMTRADE_API_KEY=__PLACEHOLDER__

# ---- WIPO PATENTSCOPE — Datos de patentes, indicador de innovación (free, registration required) ----
WIPO_API_KEY=__PLACEHOLDER__

# ---- INEGI — Oficina estadística de México (free, instant registration) ----
INEGI_TOKEN=__PLACEHOLDER__

# ---- Banxico — Banco de México, tipo de cambio (free, instant registration) ----
BANXICO_TOKEN=__PLACEHOLDER__

# ---- FRED — Federal Reserve Economic Data, EEUU (free, account required) ----
FRED_API_KEY=__PLACEHOLDER__

# ---- BEA — Bureau of Economic Analysis, EEUU (free, email registration) ----
BEA_API_KEY=__PLACEHOLDER__

# ---- BLS — Bureau of Labor Statistics, EEUU (free, registration required) ----
BLS_API_KEY=__PLACEHOLDER__

# ---- US Census Bureau — ACS/CBP/SAIPE, EEUU (free, instant registration at https://api.census.gov/data/key_signup.html) ----
CENSUS_API_KEY=__PLACEHOLDER__

# ---- Statistics Canada — Web Data Service (free, no auth required) ----
# No key needed for WDS

# ---- UN Comtrade — International trade data (free, register at https://comtradeplus.un.org/) ----
COMTRADE_API_KEY=__PLACEHOLDER__

# ---- APIs sin llave (no necesitan variable) ----
# World Bank API → https://api.worldbank.org/v2/ (free, no auth)
# Harvard Atlas of Economic Complexity → https://atlas.cid.harvard.edu/ (free, no auth)
# OECD Data → https://stats.oecd.org/ (free, no auth)
# IMF Data → https://www.imf.org/ (free, no auth)
# OpenStreetMap / Nominatim → https://nominatim.openstreetmap.org/ (free, no auth)
